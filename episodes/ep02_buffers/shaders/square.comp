/**
 * VKCompute - Episode 02: Buffer Types
 * In-place square operation: data[i] = data[i] * data[i]
 */

#version 450

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer DataBuffer {
    float data[];
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    float val = data[idx];
    data[idx] = val * val;
}
