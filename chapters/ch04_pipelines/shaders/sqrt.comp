// Chapter 04: Square root operation
#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) readonly buffer Input { float data[]; } input_buf;
layout(set = 0, binding = 1) writeonly buffer Output { float data[]; } output_buf;
layout(push_constant) uniform PushConstants { float value; };  // unused but keeps layout compatible

void main() {
    uint idx = gl_GlobalInvocationID.x;
    output_buf.data[idx] = sqrt(input_buf.data[idx]);
}
